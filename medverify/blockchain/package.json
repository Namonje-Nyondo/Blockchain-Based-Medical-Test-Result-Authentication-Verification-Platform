{
  "name": "medverify-blockchain",
  "version": "1.0.0",
  "description": "MedVerify Blockchain - Decentralized Medical Document Verification",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:watch": "hardhat test --watch",
    "test:coverage": "hardhat coverage",
    "deploy": "hardhat run scripts/deploy.ts",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:ganache": "hardhat run scripts/deploy.ts --network ganache",
    "node": "hardhat node",
    "setup-roles": "hardhat run scripts/setup-roles.ts --network localhost",
    "accounts": "hardhat accounts",
    "clean": "hardhat clean",
    "flatten": "hardhat flatten",
    "typechain": "typechain --target ethers-v6 --out-dir typechain-types './artifacts/contracts/**/*.json'",
    "docs": "solidity-docgen -i ./contracts -o ./docs"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "hardhat",
    "medical",
    "verification",
    "smart-contracts"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.0.5",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.4",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "chai": "^4.5.0",
    "ethers": "^6.11.0",
    "hardhat": "^2.22.18",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.4",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "~5.8.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.1"
  }
}
